# =============================================================================
# CyberRAG Configuration Template
# =============================================================================
# Copy this file to .env and fill in your API credentials
# Usage: Change CYBER_RAG_LLM_PROVIDER to switch between 'azure' and 'oneapi'
# =============================================================================

# =============================================================================
# LLM Provider Selection (REQUIRED)
# =============================================================================
# Supported values:
#   - azure   : Use Azure OpenAI API
#   - oneapi  : Use OneAPI/OpenAI-compatible API
# =============================================================================
CYBER_RAG_LLM_PROVIDER=azure

# =============================================================================
# Azure OpenAI Configuration
# =============================================================================
# Fill these values when CYBER_RAG_LLM_PROVIDER=azure
# --------------------------------------------------------------------------
# API Key: Your Azure OpenAI API key
# Base URL: Your Azure OpenAI endpoint base (e.g., https://xxx.openai.azure.com)
#             Note: Do NOT include /openai suffix - the SDK appends it automatically.
#             For Azure API Management gateways, use the gateway root (e.g., https://xxx.azure-api.net).
# Model Name: The deployment name in Azure (e.g., gpt-4o-mini, gpt-35-turbo)
# API Version: Azure OpenAI API version (e.g., 2024-10-21)
# --------------------------------------------------------------------------
CYBER_RAG_AZURE_API_KEY=your_azure_api_key_here
CYBER_RAG_AZURE_BASE_URL=https://your-azure-endpoint.openai.azure.com
CYBER_RAG_AZURE_MODEL_NAME=gpt-4o-mini
CYBER_RAG_AZURE_API_VERSION=2024-10-21

# =============================================================================
# OneAPI Configuration (OpenAI-compatible)
# =============================================================================
# Fill these values when CYBER_RAG_LLM_PROVIDER=oneapi
# --------------------------------------------------------------------------
# API Key: Your OneAPI or OpenAI-compatible API key
# Base URL: Your OneAPI/OpenAI-compatible endpoint (e.g., https://api.example.com/v1)
# Model Name: The model name supported by your provider
# --------------------------------------------------------------------------
CYBER_RAG_ONEAPI_API_KEY=your_oneapi_api_key_here
CYBER_RAG_ONEAPI_BASE_URL=https://your-oneapi-endpoint/v1
CYBER_RAG_ONEAPI_MODEL_NAME=deepseek-v3

# =============================================================================
# Quick Switch Guide
# =============================================================================
# To switch between providers:
#   1. Open .env file
#   2. Change CYBER_RAG_LLM_PROVIDER to either 'azure' or 'oneapi'
#   3. Ensure the corresponding section below has valid credentials
#   4. Run your script (no code changes needed!)
# =============================================================================
