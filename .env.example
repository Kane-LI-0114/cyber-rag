# =============================================================================
# CyberRAG Configuration Template
# =============================================================================
# Copy this file to .env and fill in your API credentials
# Usage: Change CYBER_RAG_LLM_PROVIDER to switch between providers
# =============================================================================

# =============================================================================
# LLM Provider Selection (REQUIRED)
# =============================================================================
# Supported values:
#   - azure        : Use Azure OpenAI API
#   - oneapi       : Use OneAPI/OpenAI-compatible API
#   - huggingface  : Use Hugging Face Inference API (OpenAI-compatible)
# =============================================================================
CYBER_RAG_LLM_PROVIDER=azure

# =============================================================================
# Azure OpenAI Configuration
# =============================================================================
# Fill these values when CYBER_RAG_LLM_PROVIDER=azure
# --------------------------------------------------------------------------
# API Key: Your Azure OpenAI API key
# Base URL: Your Azure OpenAI endpoint base (e.g., https://xxx.openai.azure.com)
#             Note: Do NOT include /openai suffix - the SDK appends it automatically.
#             For Azure API Management gateways, use the gateway root (e.g., https://xxx.azure-api.net).
# Model Name: The deployment name in Azure (e.g., gpt-4o-mini, gpt-35-turbo)
# API Version: Azure OpenAI API version (e.g., 2024-10-21)
# --------------------------------------------------------------------------
CYBER_RAG_AZURE_API_KEY=your_azure_api_key_here
CYBER_RAG_AZURE_BASE_URL=https://your-azure-endpoint.openai.azure.com
CYBER_RAG_AZURE_MODEL_NAME=gpt-4o-mini
CYBER_RAG_AZURE_API_VERSION=2024-10-21

# =============================================================================
# OneAPI Configuration (OpenAI-compatible)
# =============================================================================
# Fill these values when CYBER_RAG_LLM_PROVIDER=oneapi
# --------------------------------------------------------------------------
# API Key: Your OneAPI or OpenAI-compatible API key
# Base URL: Your OneAPI/OpenAI-compatible endpoint (e.g., https://api.example.com/v1)
# Model Name: The model name supported by your provider
# --------------------------------------------------------------------------
CYBER_RAG_ONEAPI_API_KEY=your_oneapi_api_key_here
CYBER_RAG_ONEAPI_BASE_URL=https://your-oneapi-endpoint/v1
CYBER_RAG_ONEAPI_MODEL_NAME=deepseek-v3

# =============================================================================
# DotsOCR Configuration (PDF structured layout parsing)
# =============================================================================
# DotsOCR uses a vision-language model to parse PDF pages into structured
# layout blocks (titles, sections, tables, formulas, etc.).
# If these are not set, DotsOCR falls back to the OneAPI credentials above.
# --------------------------------------------------------------------------
# API Key: Your DotsOCR API key (defaults to CYBER_RAG_ONEAPI_API_KEY)
# Endpoint: The chat completions endpoint (defaults to CYBER_RAG_ONEAPI_BASE_URL + /chat/completions)
# Model: The DotsOCR model name
# --------------------------------------------------------------------------
CYBER_RAG_DOTS_OCR_API_KEY=your_dots_ocr_api_key_here
CYBER_RAG_DOTS_OCR_ENDPOINT=https://your-oneapi-endpoint/v1/chat/completions
CYBER_RAG_DOTS_OCR_MODEL=DotsOCR

# =============================================================================
# Hugging Face Configuration (OpenAI-compatible)
# =============================================================================
# Fill these values when CYBER_RAG_LLM_PROVIDER=huggingface
# --------------------------------------------------------------------------
# API Key: Your Hugging Face API token (get from https://huggingface.co/settings/tokens)
# Base URL: The Hugging Face router endpoint (default: https://router.huggingface.co/v1)
# Model Name: The model to use (e.g., mistralai/Mistral-7B-Instruct-v0.2:featherless-ai)
# --------------------------------------------------------------------------
CYBER_RAG_HUGGINGFACE_API_KEY=hf_your_token_here
CYBER_RAG_HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
CYBER_RAG_HUGGINGFACE_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2:featherless-ai

# =============================================================================
# Judge Model Configuration (for short-answer evaluation)
# =============================================================================
# The judge model evaluates short-answer responses on a 0-1 scale.
# Recommended: Use a cheaper model for judging (e.g., gpt-4o for answers, gpt-4o-mini for judge)
# Falls back to main LLM provider/model if not explicitly set.
# --------------------------------------------------------------------------
# Provider: 'azure', 'oneapi', or 'huggingface' (defaults to CYBER_RAG_LLM_PROVIDER)
# --------------------------------------------------------------------------
CYBER_RAG_JUDGE_LLM_PROVIDER=azure

# Judge Azure OpenAI
CYBER_RAG_JUDGE_AZURE_API_KEY=your_azure_api_key_here
CYBER_RAG_JUDGE_AZURE_BASE_URL=https://your-azure-endpoint.openai.azure.com
CYBER_RAG_JUDGE_AZURE_MODEL_NAME=gpt-4o-mini
CYBER_RAG_JUDGE_AZURE_API_VERSION=2024-10-21

# Judge OneAPI
# CYBER_RAG_JUDGE_ONEAPI_API_KEY=your_oneapi_api_key_here
# CYBER_RAG_JUDGE_ONEAPI_BASE_URL=https://your-oneapi-endpoint/v1
# CYBER_RAG_JUDGE_ONEAPI_MODEL_NAME=gpt-4o-mini

# Judge HuggingFace
# CYBER_RAG_JUDGE_HUGGINGFACE_API_KEY=hf_your_token_here
# CYBER_RAG_JUDGE_HUGGINGFACE_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2

# =============================================================================
# Quick Switch Guide
# =============================================================================
# To switch between providers:
#   1. Open .env file
#   2. Change CYBER_RAG_LLM_PROVIDER to 'azure', 'oneapi', or 'huggingface'
#   3. Ensure the corresponding section below has valid credentials
#   4. Run your script (no code changes needed!)
# =============================================================================
